// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Modello per i contatti dal form contatti
model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  service   String?
  message   String
  createdAt DateTime @default(now())
  read      Boolean  @default(false)
}

// Modello per gli ordini dal checkout
model Order {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String
  phone       String?
  address     String?
  city        String?
  postalCode  String?
  country     String   @default("Deutschland")

  // Dettagli ordine
  items       Json
  totalPrice  Float

  // PayPal
  paypalOrderId String?
  paypalStatus  String?

  createdAt   DateTime @default(now())
  status      String   @default("pending") // pending, completed, cancelled
}

// Documenti generati: contratti + Rechnung (archivio)
model Document {
  id          String   @id @default(cuid())
  type        String   // "contract" | "rechnung"
  clientName  String
  serviceType String?  // pacchetto (per contratti)
  rechnungNr  String?  // numero fattura (per Rechnung)
  total       Float    @default(0)
  // Snapshot completo per ri-aprire/stampare il documento
  contractData Json?
  rechnungData Json?
  createdAt   DateTime @default(now())
}
